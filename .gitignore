# Local environment secrets
**/.env
**/.env.*
!**/.env.example
be/file.env

# Dependency folders
be/vendor/
**/node_modules/

# Laravel runtime/cache
be/storage/*.key
be/storage/logs/*
be/storage/framework/cache/*
be/storage/framework/sessions/*
be/storage/framework/views/*
be/bootstrap/cache/*.php
be/.phpunit.result.cache

# Flutter/Dart generated files
fe/.dart_tool/
fe/build/
fe/**/build/
fe/.flutter-plugins
fe/.flutter-plugins-dependencies
fe/**/Flutter/.last_build_id

# IDE and OS files
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db

# Nested git backup created while converting this folder to a root repo
.fe-git-backup/
